# OCP Maintenance AI (AMS) — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------- Database ----------
# SQLite (default, for development):
DATABASE_URL=sqlite:///./ocp_maintenance.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/ocp_maintenance

# ---------- Claude API ----------
# Required for agent workflow (M1→M4). Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ---------- OpenAI / Whisper ----------
# Optional — required for voice transcription (D-1). If not set, voice capture falls back to manual text entry.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Whisper model to use (default: whisper-1). Supports multilingual (FR/AR/EN/ES).
WHISPER_MODEL=whisper-1

# ---------- Admin ----------
# Required for destructive endpoints (POST /admin/seed-database, DELETE /admin/reset-database).
# Set to any secret string. If empty, admin endpoints return 503.
AMS_ADMIN_API_KEY=

# ---------- CORS ----------
# Comma-separated list of allowed origins for the API.
AMS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8501

# ---------- SAP Mock Data ----------
# Directory containing synthetic SAP PM JSON files for testing.
SAP_MOCK_DIR=sap_mock/data

# ---------- Debug ----------
# Set to "true" to enable debug mode (verbose logging, auto-reload).
DEBUG=false
